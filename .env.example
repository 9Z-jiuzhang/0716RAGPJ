# ============================================
# 应用配置
# ============================================
APP_NAME=AI-KnowledgeBase-RAG
APP_VERSION=2.1.0
DEBUG=false
# local=本机联调；cloud=云端生产（启动强制校验密钥/CORS/PUBLIC_BASE_URL）
DEPLOYMENT_MODE=local
SECRET_KEY=<请填写>
# 公网根地址（无尾斜杠）。云端示例：https://kb.example.com ；本机可留空或 http://localhost:18080
PUBLIC_BASE_URL=
# 唯一超管账号 super 的密码（仅能通过此处修改；改后需重启 API）
SUPER_ADMIN_PASSWORD=Super123!
# 每次启动是否把 DB 中 super 密码同步为上面的值（云端首次引导后建议改为 false）
SUPER_ADMIN_SYNC_PASSWORD=true
# 是否播种演示账号 admin/staff_*（云端务必 false）
SEED_DEMO_USERS=true
# 是否开放 POST /auth/register（云端可 false）
AUTH_REGISTER_ENABLED=true
# 是否公开 /metrics（云端建议 false）
METRICS_PUBLIC=true

# ============================================
# 数据库 PostgreSQL
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_base
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=<请填写>

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# 云端 docker-compose.prod.yml 要求设置；本机可留空
REDIS_PASSWORD=

# ============================================
# 向量数据库 Chroma
# ============================================
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ============================================
# 对象存储 MinIO
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<请填写>
MINIO_SECRET_KEY=<请填写>
MINIO_BUCKET=knowledge-base-docs

# ============================================
# LLM 大模型（千问 / 百炼业务空间，OpenAI 兼容模式）
# ============================================
LLM_PROVIDER=dashscope
LLM_API_KEY=<请填写>
LLM_MODEL=qwen3.7-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 主回答开启思考：流式 reasoning_content 包装为 <think>，前端气泡展示并在结束后折叠
LLM_ENABLE_THINKING=true
LLM_THINKING_BUDGET=2048

# Guard 与 Query 预处理默认复用主 LLM；地址和密钥留空时继承主连接。
LLM_GUARD_MODEL=qwen3.7-plus
LLM_GUARD_BASE_URL=
LLM_GUARD_API_KEY=
LLM_GUARD_TIMEOUT_SECONDS=20
QA_QUERY_PROCESSING_MODEL=qwen3.7-plus
QA_QUERY_PROCESSING_BASE_URL=
QA_QUERY_PROCESSING_API_KEY=
QA_QUERY_PROCESSING_TIMEOUT_SECONDS=30

# ============================================
# Embedding 嵌入模型（千问）
# ============================================
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=<请填写>
EMBEDDING_MODEL_NAME=qwen3.7-text-embedding
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# Rerank 重排模型（千问 DashScope；密钥为空时自动降级为原始检索排序）
# ============================================
RERANK_PROVIDER=dashscope
RERANK_API_KEY=
RERANK_MODEL=qwen3-vl-rerank
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANK_TIMEOUT_SECONDS=30
RERANK_CANDIDATE_MULTIPLIER=4

# ============================================
# Langfuse 可观测（Compose 不含 Langfuse 容器）
# ============================================
# 云端示例：https://cloud.langfuse.com 或 https://us.cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=<请填写>
LANGFUSE_SECRET_KEY=<请填写>
# 以下三项仅自建 Langfuse UI 时需要，后端 Settings 不读取
# LANGFUSE_NEXTAUTH_SECRET=<自建时填写>
# LANGFUSE_SALT=<自建时填写>
# LANGFUSE_ENCRYPTION_KEY=<自建时填写>

# ============================================
# JWT 认证
# ============================================
JWT_SECRET_KEY=<请填写>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# 逗号分隔；同域反代可写 PUBLIC_BASE_URL 同值。云端禁止 *
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# ============================================
# 监控
# ============================================
GRAFANA_ADMIN_PASSWORD=<请填写>

# ============================================
# 日志
# ============================================
LOG_LEVEL=INFO
# LOG_DIR 默认项目根目录 data/logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# ============================================
# 快照策略（产品手册 5.8.4）
# ============================================
SNAPSHOT_MAX_COUNT=50
SNAPSHOT_RETENTION_DAYS=90

# ============================================
# 智能问答与会话记忆（产品手册 5.6）
# ============================================
# 上下文窗口：保留最近 N 轮对话（一问一答计为 1 轮）
QA_CONTEXT_WINDOW=10
# Redis 热缓存 TTL（分钟），读写时续期
QA_SESSION_TTL_MINUTES=30
# 闲置超过该分钟数未问答 → PG 标为 expired 并清 Redis（历史仍可查看/继续提问）
QA_SESSION_IDLE_EXPIRE_MINUTES=30
# 后台扫描闲置会话间隔（秒）
QA_SESSION_EXPIRE_SWEEP_SECONDS=60
# 历史物理保留天数；超过后消息与空会话自动删除
QA_HISTORY_RETENTION_DAYS=7
# 单个注册用户或访客跨会话最多保留的问答轮数
QA_HISTORY_MAX_TURNS=20
# 后台历史清理扫描间隔（秒）
QA_HISTORY_RETENTION_SWEEP_SECONDS=300
# 默认检索策略：hybrid（推荐）| vector | fulltext
QA_DEFAULT_STRATEGY=hybrid
# 默认返回检索片段数量
QA_DEFAULT_TOP_K=5
# 相关性得分阈值，低于此值的片段将被过滤
QA_RELEVANCE_THRESHOLD=0.3
# RRF 融合排序参数 k（Reciprocal Rank Fusion）
QA_RRF_K=60
# Query 改写：补全指代并生成可独立检索的主查询
QA_QUERY_REWRITE_ENABLED=true
# Query 扩展：生成语义相近、关键词互补的候选查询
QA_QUERY_EXPANSION_ENABLED=false
QA_QUERY_EXPANSION_COUNT=1
# HyDE：生成假设文档，仅用于向量嵌入召回，不作为回答依据
QA_HYDE_ENABLED=false
QA_QUERY_PROCESSING_MAX_TOKENS=768
# 角色缓存知识库：默认每 7 天生成 20 个文档问题，并补充 5 个历史高频问题
ROLE_CACHE_DEFAULT_INTERVAL_DAYS=7
ROLE_CACHE_DOCUMENT_QUESTION_COUNT=20
ROLE_CACHE_HISTORY_QUESTION_COUNT=5
ROLE_CACHE_DOCUMENT_CHUNK_LIMIT=30
ROLE_CACHE_DOCUMENT_CHARS_PER_CHUNK=800
ROLE_CACHE_LLM_MAX_TOKENS=4096
# 周期调度器检查间隔（秒）；每个角色的实际检测周期由管理端配置
ROLE_CACHE_SCHEDULER_POLL_SECONDS=3600
# LLM Guard：本地高风险规则优先，无法明确归类时调用 LLM 意图分类器
LLM_GUARD_ENABLED=true
LLM_GUARD_CLASSIFIER_ENABLED=true
LLM_GUARD_BLOCK_THRESHOLD=0.65
# true 表示分类器不可用时拒绝请求；默认 false 保持可用性，本地恶意规则仍生效
LLM_GUARD_FAIL_CLOSED=false
LLM_GUARD_PREVIEW_MAX_CHARS=200
# RAGAS 评估（默认关闭 RAGAS 匿名遥测）
RAGAS_ENABLED=true
RAGAS_DO_NOT_TRACK=true
RAGAS_DEFAULT_SAMPLE_LIMIT=10
RAGAS_MAX_SAMPLE_LIMIT=50
RAGAS_MAX_CONTEXTS_PER_SAMPLE=10
RAGAS_CONTEXT_MAX_CHARS=3000
# 访客临时会话 Cookie/Header 标识有效期（分钟）
QA_GUEST_SESSION_TTL_MINUTES=30
# Redis 逻辑库编号
REDIS_DB=0
# Chroma 多租户标识（Client-Server 模式）
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
