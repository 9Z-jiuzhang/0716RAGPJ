{
  "uid": "rag-qa",
  "title": "问答分析",
  "tags": ["rag", "qa"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "问答请求量",
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (status) (rate(qa_requests_total[5m]))", "legendFormat": "{{status}}", "refId": "A"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "type": "timeseries",
      "title": "问答端到端延迟",
      "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(qa_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(qa_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"}
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "type": "timeseries",
      "title": "检索耗时分布",
      "id": 3,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(qa_retrieval_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(qa_retrieval_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"}
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    }
  ]
}
