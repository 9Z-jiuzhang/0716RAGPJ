# ============================================
# 应用配置
# ============================================
APP_NAME=AI-KnowledgeBase-RAG
APP_VERSION=2.1.0
DEBUG=false
SECRET_KEY=<请填写>

# ============================================
# 数据库 PostgreSQL
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_base
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=<请填写>

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# 向量数据库 Chroma
# ============================================
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ============================================
# 对象存储 MinIO
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<请填写>
MINIO_SECRET_KEY=<请填写>
MINIO_BUCKET=knowledge-base-docs

# ============================================
# LLM 大模型
# ============================================
LLM_PROVIDER=openai
LLM_API_KEY=<请填写>
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# ============================================
# Embedding 嵌入模型
# ============================================
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=<请填写>
EMBEDDING_MODEL_NAME=text-embedding-v3
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# Rerank 重排模型（可选）
# ============================================
RERANK_PROVIDER=
RERANK_API_KEY=
RERANK_MODEL=

# ============================================
# Langfuse 可观测
# ============================================
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_PUBLIC_KEY=<请填写>
LANGFUSE_SECRET_KEY=<请填写>
LANGFUSE_NEXTAUTH_SECRET=<请填写>
LANGFUSE_SALT=<请填写>
LANGFUSE_ENCRYPTION_KEY=<请填写>

# ============================================
# JWT 认证
# ============================================
JWT_SECRET_KEY=<请填写>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 监控
# ============================================
GRAFANA_ADMIN_PASSWORD=<请填写>

# ============================================
# 日志
# ============================================
LOG_LEVEL=INFO
# LOG_DIR 默认项目根目录 data/logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# ============================================
# 快照策略（产品手册 5.8.4）
# ============================================
SNAPSHOT_MAX_COUNT=50
SNAPSHOT_RETENTION_DAYS=90

# ============================================
# 智能问答与会话记忆（产品手册 5.6）
# ============================================
# 上下文窗口：保留最近 N 轮对话（一问一答计为 1 轮）
QA_CONTEXT_WINDOW=10
# 会话闲置过期时间（分钟），Redis TTL 与此对齐
QA_SESSION_TTL_MINUTES=30
# 默认检索策略：hybrid（推荐）| vector | fulltext
QA_DEFAULT_STRATEGY=hybrid
# 默认返回检索片段数量
QA_DEFAULT_TOP_K=5
# 相关性得分阈值，低于此值的片段将被过滤
QA_RELEVANCE_THRESHOLD=0.3
# RRF 融合排序参数 k（Reciprocal Rank Fusion）
QA_RRF_K=60
# 访客临时会话 Cookie/Header 标识有效期（分钟）
QA_GUEST_SESSION_TTL_MINUTES=30
# Redis 逻辑库编号
REDIS_DB=0
# Chroma 多租户标识（Client-Server 模式）
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
